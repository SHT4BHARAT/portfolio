---
const faqs = [
  {
    question: "What is a Forward Deployed Engineer?",
    answer: "A Forward Deployed Engineer bridges the gap between product development and client needs. They architect solutions directly for real-world deployment, working closely with stakeholders to deliver production-ready systems. In my case, I specialize in Autonomous Agentic Workflows, Voice AI, and LLM Pipelines — building AI-native products that ship to production."
  },
  {
    question: "What projects have I built?",
    answer: "I've built 7 production-grade projects including Samvad (Voice AI Meeting Agent), Agentic Honey-Pot (autonomous scam detection), Call Center Compliance API, EchoPay (offline P2P payments), Multilingual Mandi (agricultural trading platform), AI Email Categorization Agent, and OpenENV Cloud Security Audit Environment. Most are deployed with 99%+ uptime."
  },
  {
    question: "What technologies do I specialize in?",
    answer: "I specialize in AI Agent Orchestration (LangChain, LangGraph, CrewAI, OpenAI API, Gemini API), Backend Systems (Python, FastAPI, Node.js, PostgreSQL, Redis), Infrastructure (Docker, AWS/GCP, Vercel, Railway), and Solutions Engineering (Rapid PoC Development, API Integration, System Design)."
  },
  {
    question: "How quickly can I build an MVP?",
    answer: "I can go from idea to production MVP in days, not weeks. For example, I built EchoPay (an offline P2P payment system using high-frequency audio) from idea to MVP in under 48 hours during the MLBhopal GenAI Hackathon, winning Runner-up."
  },
  {
    question: "What is my educational background?",
    answer: "I'm pursuing a Bachelor of Technology in Computer Science & Information Technology at Sagar Institute of Research & Technology, Bhopal (2023-2027) with a GPA of 7.64/10.00. Coursework includes Data Structures & Algorithms, Object-Oriented Programming, Database Management Systems, and Operating Systems."
  },
  {
    question: "Where am I located and am I open to remote work?",
    answer: "I'm based in Bhopal, Madhya Pradesh, India. I'm fully remote-ready and open to relocation for the right opportunity."
  }
];
---

<section id="faq" class="section-wrapper" aria-labelledby="faq-heading">
  <h2 id="faq-heading" class="text-gradient" style="font-size: clamp(2.5rem, 8vw, 4.5rem); font-weight: 900; margin-bottom: 60px;">
    Frequently Asked Questions.
  </h2>

  <div style="max-width: 800px; margin: 0 auto;">
    {faqs.map((faq, i) => (
      <details class="glass-card" style="padding: 32px; margin-bottom: 16px; cursor: pointer;">
        <summary style="font-size: 1.2rem; font-weight: 800; margin-bottom: 16px; list-style: none; display: flex; justify-content: space-between; align-items: center;">
          {faq.question}
          <span style="color: var(--accent-primary); font-size: 1.5rem; transition: transform 0.3s ease;">+</span>
        </summary>
        <p style="color: var(--text-dim); line-height: 1.8; font-size: 1rem;">{faq.answer}</p>
      </details>
    ))}
  </div>

  <style>
    details[open] summary span {
      transform: rotate(45deg);
    }
    details summary::-webkit-details-marker {
      display: none;
    }
  </style>
</section>
